*~

# === Misc ===
*.json
# EntityGraph JSON Schema contracts must be tracked (see docs/optimization.md A-1)
!mosaic/schemas/*.json
# Dataset files must be tracked
!dataset/**/*.json
# Example data must be tracked
!example/*.json

# Example pipeline outputs (graphs, LLM I/O, eval results)
example/output/*.pkl

# Experiment run artifacts (large: graph snapshots, LLM I/O, eval results)
experiments/**/runs/**
experiments/**/results/**
!experiments/**/results/.gitkeep
!experiments/**/runs/.gitkeep

# === Mosaic: config & secrets ===
config/*.cfg
**/config/*.cfg
*.env
.env.*

# === Mosaic: embedding models (large binaries) ===
mosaic/embedding_models/
mosaic/src/embedding_models/

# === Mosaic: runtime / results ===
mosaic/log/
mosaic/src/locomo results/
mosaic/src/error_case/results/
mosaic/src/error_case/conflict/results/
*.pkl
*.xlsx

# === LaTeX (Manuscript) ===
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.lof
*.lot

# === Untracked data / temp ===
temp_results/
dataset/halumem/

# === OS ===
.DS_Store
Thumbs.db
nohup.out
